# ─── CISSP Coach configuration ───────────────────────────────────────
# Copy this file to `.env` and fill in your keys.
# Both keys are optional individually, but at least one must be set.

# Required to use OpenAI / GPT models
OPENAI_API_KEY=

# Required to use Anthropic / Claude models
ANTHROPIC_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────
# Bind address. Keep on 127.0.0.1 unless you know what you're doing.
BIND_ADDR=127.0.0.1:7878

# Where the SQLite database (and future data) lives.
DATA_DIR=./data

# ─── UI defaults ─────────────────────────────────────────────────────
# Used the very first time the app boots; can be changed in Settings.
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# ─── Logging ─────────────────────────────────────────────────────────
# Standard tracing-subscriber filter. Examples:
#   RUST_LOG=info
#   RUST_LOG=cissp_coach=debug,tower_http=info
RUST_LOG=info
